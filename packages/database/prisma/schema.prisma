generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subject {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  chapters  Chapter[]
  tests     Test[]

  @@map("subjects")
}

model Chapter {
  id        String   @id @default(uuid())
  subjectId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   Subject  @relation(fields: [subjectId], references: [id])
  topics    Topic[]

  @@unique([subjectId, name])
  @@map("chapters")
}

model Topic {
  id        String   @id @default(uuid())
  chapterId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapter   Chapter    @relation(fields: [chapterId], references: [id])
  questions Question[]

  @@unique([chapterId, name])
  @@map("topics")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  INTEGER
}

enum QuestionStatus {
  DRAFT
  PUBLISHED
}

model Question {
  id               String         @id @default(uuid())
  topicId          String
  type             QuestionType
  status           QuestionStatus @default(DRAFT)
  questionText     String?
  questionImageUrl String?
  integerAnswer    Int?
  appearanceCount  Int            @default(0)
  lastAppearedAt   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  topic         Topic          @relation(fields: [topicId], references: [id])
  options       Option[]
  testQuestions TestQuestion[]

  @@map("questions")
}

model Option {
  id             String  @id @default(uuid())
  questionId     String
  position       Int
  optionText     String?
  optionImageUrl String?
  isCorrect      Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, position])
  @@map("options")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum UserRole {
  TEACHER
  STUDENT
}

model Teacher {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tests Test[]

  @@map("teachers")
}

model Student {
  id        String   @id @default(uuid())
  fullName  String
  phone     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}

// ─── Tests ───────────────────────────────────────────────────────────────────

enum TestStatus {
  DRAFT
  SCHEDULED
  COMPLETED
}

model Test {
  id              String     @id @default(uuid())
  name            String
  teacherId       String
  subjectId       String
  durationMinutes Int
  scheduledAt     DateTime
  status          TestStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  teacher       Teacher        @relation(fields: [teacherId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id])
  testQuestions TestQuestion[]

  @@map("tests")
}

model TestQuestion {
  id                 String       @id @default(uuid())
  testId             String
  originalQuestionId String
  questionText       String?
  questionImageUrl   String?
  questionType       QuestionType
  optionsJson        Json
  correctAnswerJson  Json
  position           Int
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  test             Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  originalQuestion Question @relation(fields: [originalQuestionId], references: [id])

  @@unique([testId, position])
  @@map("test_questions")
}
