# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
WORKER_PORT=3003
BOT_PORT=3002
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
BOT_URL=http://localhost:3002

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_minimum_32_chars_long_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_another_minimum_32_chars_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://scientia:scientia_dev@localhost:5432/scientia
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABC-your-bot-token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_GROUP_ID=-1001234567890
TELEGRAM_WEBHOOK_URL=https://bot.yourdomain.com/webhook

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RATE_LIMIT_RPM=60

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=scientia-storage
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=scientia_questions

# ─── BullMQ / Queue ───────────────────────────────────────────────────────────
QUEUE_PREFIX=scientia
WORKER_CONCURRENCY_PDF_INGEST=2
WORKER_CONCURRENCY_PAGE_EXTRACT=5
WORKER_CONCURRENCY_PDF_STITCH=3
PAGE_EXTRACT_RATE_LIMIT_RPM=60

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
