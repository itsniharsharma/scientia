{
  "name": "@scientia/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file ../.env src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx --env-file ../.env src/index.ts",
    "start:prod": "prisma migrate deploy && tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --env-file ../.env",
    "db:migrate": "prisma migrate dev --env-file ../.env",
    "db:migrate:deploy": "prisma migrate deploy --env-file ../.env"
  },
  "prisma": {
    "schema": "../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.17.0",
    "tsx": "^4.16.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "pdf-parse": "^2.4.5",
    "supertest": "^7.2.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
